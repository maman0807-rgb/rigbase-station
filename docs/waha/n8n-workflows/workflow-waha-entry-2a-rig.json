      []
    ]},
    "Ambil Semua Rig": { "main": [[{ "node": "Format Daftar Rig", "type": "main", "index": 0 }]] },
    "Format Daftar Rig": { "main": [[{ "node": "Kirim Balasan ke WA", "type": "main", "index": 0 }]] }
  },
  "active": false,
