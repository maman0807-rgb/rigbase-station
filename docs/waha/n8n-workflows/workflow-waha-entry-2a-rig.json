    "Gabung Data Whitelist": { "main": [[{ "node": "IF Whitelisted", "type": "main", "index": 0 }]] },
    "IF Whitelisted": { "main": [
      [{ "node": "Klasifikasi Pesan", "type": "main", "index": 0 }],
      []
    ]},
    "Klasifikasi Pesan": { "main": [[{ "node": "IF Command Rig", "type": "main", "index": 0 }]] },
    "IF Command Rig": { "main": [
